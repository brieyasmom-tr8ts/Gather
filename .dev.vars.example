# Admin password for the dashboard
ADMIN_PASSWORD=your-secure-admin-password

# Secret key for signing auth tokens
AUTH_SECRET=your-random-secret-key-min-32-chars

# Resend API key for sending emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email sender address (must be verified in Resend)
EMAIL_FROM=GiveSendGo Gala <gala@yourdomain.com>

# Base URL of the deployed app
BASE_URL=https://your-app.pages.dev

# Maximum number of attendees (0 = unlimited)
MAX_ATTENDEES=0
